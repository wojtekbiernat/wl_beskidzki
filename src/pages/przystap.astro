---
import Layout from '../layouts/Layout.astro';

// ── Server endpoint ───────────────────────────────────────────────────────────

const SERVER_CHECKOUT_URL = 'https://korunahor.cz/wl_beskidzki/checkout.php';

// ── Prices ────────────────────────────────────────────────────────────────────
const BOOK_PRICE = '43 zł';

// ── Stripe Price IDs ──────────────────────────────────────────────────────────
// Get these from Stripe Dashboard → Products → (product) → Pricing.
// Must match the IDs configured in server/.env (STRIPE_PRICE_* vars).
const MAIN_PRICE_ID = 'price_1TACezPCvjb6WUdamFdMW5CO';

const ADDONS = [
  { id: 'kws',  priceId: 'price_1TACg1PCvjb6WUdaSIOG3USx',  cover: 'KWŚ_Cover.jpg',           title: 'Korona Woj. Śląskiego',       price: '20 zł' },
  { id: 'ggmf', priceId: 'price_1TACguPCvjb6WUdan20UcyeX', cover: 'GGMF_Cover.jpg',          title: 'Gł. Grzbiet Małej Fatry',    price: '15 zł' },
  { id: 'ggwf', priceId: 'price_1TACitPCvjb6WUdaajVADkSr', cover: 'GGWF_Cover.jpg',          title: 'Gł. Grzbiet Wielkiej Fatry', price: '15 zł' },
  { id: 'ggnt', priceId: 'price_1TACjOPCvjb6WUdaaDSH9auo', cover: 'GGNT_Cover.jpg',          title: 'Gł. Grzbiet Niżnych Tatr',   price: '15 zł' },
  { id: 'kw',   priceId: 'price_1TACkoPCvjb6WUda6GxrUBrT',   cover: 'KORONA_WEGIER_Cover.jpg', title: 'Korona Wzgórz i Gór Węgier', price: '20 zł' },
];

// Only show add-ons whose Stripe Price ID has been filled in.
// To activate a book: replace its placeholder with a real price_xxx value.
const ACTIVE_ADDONS = ADDONS.filter(a => !a.priceId.startsWith('['));

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
  title="Przystąp"
  description="Przystąp do projektu Beskidzki Włóczykij — zamów Odznakę i zgłoś swoje szczyty."
>

  <div class="page-header">
    <div class="container">
      <h1>Przystąp do projektu</h1>
      <p>Zamów książeczkę i zacznij zdobywać szczyty</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container">
      <div class="order-box">

        <!-- ── Main book ────────────────────────────────────────────────── -->
        <div class="order-summary">
          <img src={`${base}img/BookCover.jpg`} alt="Okładka książki" class="cover-img" />
          <div class="order-info">
            <h2>Książeczka odznaki Beskidzki Włóczykij</h2>
            <p class="price">{BOOK_PRICE}</p>
            <p class="price-note">Cena nie zawiera kosztów wysyłki.</p>
            <ul class="order-hints">
              <li>Liczbę książeczek możesz zmienić przy kasie</li>
              <li>Zniżki naliczane są automatycznie</li>
              <li>Kod rabatowy możesz dodać przy kasie</li>
            </ul>
          </div>
        </div>

        <!-- ── Add-ons ───────────────────────────────────────────────────── -->
        <!-- Section is hidden until at least one add-on has a real Stripe Price ID -->
        {ACTIVE_ADDONS.length > 0 && (
          <div class="addons-section">
            <h3>Dokup inne książeczki</h3>
            <p class="addons-desc">Zaznacz publikacje, które chcesz dołączyć do zamówienia.</p>
            <div class="addons-grid">
              {ACTIVE_ADDONS.map(addon => (
                <label class="addon-card" for={`addon-${addon.id}`}>
                  <input type="checkbox" id={`addon-${addon.id}`} class="addon-cb" value={addon.priceId} />
                  <div class="addon-check">✓</div>
                  <img src={`${base}img/${addon.cover}`} alt={addon.title} class="addon-cover" />
                  <div class="addon-info">
                    <span class="addon-title">{addon.title}</span>
                    <span class="addon-price">{addon.price}</span>
                  </div>
                </label>
              ))}
            </div>
            <a href={`${base}inne-projekty/`} class="other-projects-link">Poznaj inne projekty &rarr;</a>
          </div>
        )}

        <!-- ── Payment ───────────────────────────────────────────────────── -->
        <div class="payment-section">
          <h3>Wybierz sposób płatności</h3>
          <p class="payment-desc">
            Płatność realizowana jest przez <strong>Stripe</strong> &mdash; bezpieczną,
            szyfrowaną bramkę płatniczą. Akceptujemy:
          </p>
          <ul class="payment-methods">
            <li>&#128241; BLIK</li>
            <li><img src={`${base}img/przelewy24.svg`} alt="Przelewy24" class="pm-logo" />Przelewy24</li>
            <li>&#128179; Karta płatnicza</li>
            <li>&#128242; Google Pay / Apple Pay</li>
          </ul>

          <!-- ── Shipping method ──────────────────────────────────────── -->
          <div class="shipping-method-group">
            <p class="shipping-method-title">Sposób dostawy</p>
            <label class="shipping-option-label">
              <input type="radio" name="shipping-method" id="ship-paczkomat" value="paczkomat" />
              <span class="shipping-option-content">
                <span class="shipping-option-name">&#128230; Dostawa do Paczkomatu</span>
                <span class="shipping-option-note">InPost &ndash; wybierz paczkomat na mapie</span>
              </span>
            </label>
            <div id="paczkomat-picker" class="paczkomat-picker" hidden>
              <button type="button" id="open-map-btn" class="btn-pick-paczkomat">Wybierz Paczkomat na mapie</button>
              <div id="selected-paczkomat" class="selected-paczkomat" hidden>
                <span class="paczkomat-icon">&#128205;</span>
                <div>
                  <span id="paczkomat-name" class="paczkomat-name"></span>
                  <span id="paczkomat-address" class="paczkomat-address"></span>
                </div>
              </div>
            </div>
            <label class="shipping-option-label">
              <input type="radio" name="shipping-method" id="ship-adres" value="adres" />
              <span class="shipping-option-content">
                <span class="shipping-option-name">&#127968; Dostawa na adres</span>
                <span class="shipping-option-note">Poprosimy Ci&#281; o adres w kolejnym kroku</span>
              </span>
            </label>
          </div>

          <div class="consent-group">
            <label class="consent-label">
              <input type="checkbox" id="cb-regulamin" />
              <span>Zapoznałem/am się z <a href={`${base}regulamin/regulamin-sklepu/`} target="_blank" rel="noopener">Regulaminem sklepu</a> i <a href={`${base}regulamin/polityka-prywatnosci/`} target="_blank" rel="noopener">Polityką prywatności</a> i akceptuję ich postanowienia. <span class="consent-required">*</span></span>
            </label>
            <label class="consent-label">
              <input type="checkbox" id="cb-newsletter" />
              <span>Chcę otrzymywać newsletter z informacjami o projekcie „Beskidzki Włóczykij", nowych publikacjach i aktualnościach. Wiem, że zgodę mogę wycofać w każdej chwili. <span class="consent-optional">(opcjonalne)</span></span>
            </label>
            <p class="newsletter-note">Newsletter wysyłamy wyłącznie od czasu do czasu, z informacjami o projekcie, książeczkach i nowościach. Bez spamu.</p>
          </div>
          <button id="checkout-btn" class="btn btn-order" disabled>
            Przejdź do kasy &rarr;
          </button>
          <p id="checkout-error" class="checkout-error" hidden></p>
          <p class="secure-note">&#128274; Płatność chroniona szyfrowaniem SSL/TLS</p>
        </div>

        <!-- ── Shipping ──────────────────────────────────────────────────── -->
        <div class="shipping-info">
          <h3>Koszty wysyłki (z pakowaniem)</h3>

          <p class="shipping-tier-label">1–3 książeczki</p>
          <table>
            <tbody>
              <tr><td>InPost (paczkomat)</td><td>12,50 zł</td></tr>
              <tr><td>DPD (kurier)</td>        <td>6,00 zł</td></tr>
              <tr><td>DHL (kurier)</td>        <td>11,00 zł</td></tr>
            </tbody>
          </table>

          <p class="shipping-tier-label">4–10 książeczek</p>
          <table>
            <tbody>
              <tr><td>InPost (paczkomat)</td><td>17,50 zł</td></tr>
              <tr><td>DPD (kurier)</td>        <td>15,00 zł</td></tr>
              <tr><td>DHL (kurier)</td>        <td>15,50 zł</td></tr>
            </tbody>
          </table>

          <p class="free-shipping">✅ Powyżej 10 książeczek — <strong>wysyłka gratis</strong> (DPD lub InPost)</p>
        </div>

        <!-- ── PTTK ──────────────────────────────────────────────────────── -->
        <div class="pttk-note">
          <h3>Zakup stacjonarny</h3>
          <p>Książeczkę można nabyć osobiście w <strong>PTTK Katowice</strong> w cenie <strong>43 zł</strong>. Dostępność w sprzedaży stacjonarnej może być ograniczona.</p>
        </div>

      </div>
    </div>
  </div>

</Layout>

<!-- Pass server URL and main price ID to the inline script -->
<script id="checkout-data" type="application/json" set:html={JSON.stringify({
  serverUrl:   SERVER_CHECKOUT_URL,
  mainPriceId: MAIN_PRICE_ID,
})}></script>

<script is:inline>
  (function () {
    var cfg   = JSON.parse(document.getElementById('checkout-data').textContent);
    var btn   = document.getElementById('checkout-btn');
    var errEl = document.getElementById('checkout-error');
    var cbReg  = document.getElementById('cb-regulamin');
    var cbNews = document.getElementById('cb-newsletter');
    if (!btn) return;

    var selectedPaczkomat        = null;
    var selectedPaczkomatAddress = null;
    var shipPaczkomat  = document.getElementById('ship-paczkomat');
    var shipAdres      = document.getElementById('ship-adres');
    var paczkomatPicker = document.getElementById('paczkomat-picker');
    var openMapBtn      = document.getElementById('open-map-btn');
    var selPaczkDiv     = document.getElementById('selected-paczkomat');
    var paczkomatNameEl = document.getElementById('paczkomat-name');
    var paczkomatAddrEl = document.getElementById('paczkomat-address');

    function isShippingReady() {
      if (shipAdres && shipAdres.checked) return true;
      if (shipPaczkomat && shipPaczkomat.checked && selectedPaczkomat) return true;
      return false;
    }
    function updateBtn() {
      btn.disabled = !(cbReg && cbReg.checked && isShippingReady());
    }

    if (cbReg) cbReg.addEventListener('change', updateBtn);

    if (shipPaczkomat) shipPaczkomat.addEventListener('change', function () {
      paczkomatPicker.hidden = !shipPaczkomat.checked;
      updateBtn();
    });
    if (shipAdres) shipAdres.addEventListener('change', function () {
      if (shipAdres.checked) paczkomatPicker.hidden = true;
      updateBtn();
    });

    function loadEasyPack(cb) {
      if (window.easyPack) { cb(); return; }
      var link = document.createElement('link');
      link.rel  = 'stylesheet';
      link.href = 'https://geowidget.easypack24.net/css/easypack.css';
      document.head.appendChild(link);
      var s = document.createElement('script');
      s.src = 'https://geowidget.easypack24.net/js/sdk-for-maps.js';
      s.onload = function () {
        easyPack.init({ defaultLocale: 'pl', mapType: 'osm', searchType: 'osm',
          points: { types: ['parcel_locker'] }, display: { showTypesFilters: false } });
        cb();
      };
      document.head.appendChild(s);
    }

    if (openMapBtn) openMapBtn.addEventListener('click', function () {
      loadEasyPack(function () {
        easyPack.modalMap(function (point, modal) {
          modal.closeModal();
          selectedPaczkomat        = point.name;
          selectedPaczkomatAddress = point.address.line1 + ', ' + point.address.line2;
          paczkomatNameEl.textContent = point.name;
          paczkomatAddrEl.textContent = selectedPaczkomatAddress;
          selPaczkDiv.hidden  = false;
          openMapBtn.textContent = 'Zmień Paczkomat';
          updateBtn();
        }, { width: 500, height: 600 });
      });
    });

    btn.addEventListener('click', function () {
      if (cfg.serverUrl.indexOf('[') !== -1) {
        errEl.textContent = 'Konfiguracja: ustaw SERVER_CHECKOUT_URL w przystap.astro na adres twojego serwera.';
        errEl.hidden = false;
        return;
      }
      if (cfg.mainPriceId.indexOf('[') !== -1) {
        errEl.textContent = 'Konfiguracja: ustaw MAIN_PRICE_ID w przystap.astro na rzeczywisty Stripe Price ID (price_...).';
        errEl.hidden = false;
        return;
      }

      var items = [{ price: cfg.mainPriceId, quantity: 1 }];
      document.querySelectorAll('.addon-cb:checked').forEach(function (cb) {
        items.push({ price: cb.value, quantity: 1 });
      });

      btn.disabled    = true;
      btn.textContent = 'Ładowanie\u2026';
      errEl.hidden    = true;

      fetch(cfg.serverUrl, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          items:             items,
          newsletter:        !!(cbNews && cbNews.checked),
          regulamin:         true,
          shipping_method:   shipPaczkomat && shipPaczkomat.checked ? 'paczkomat' : 'adres',
          paczkomat_id:      selectedPaczkomat || '',
          paczkomat_address: selectedPaczkomatAddress || '',
        }),
      })
        .then(function (res) { return res.json(); })
        .then(function (json) {
          if (json.url) {
            window.location.href = json.url;
          } else {
            throw new Error(json.error || 'Nieznany błąd');
          }
        })
        .catch(function (err) {
          btn.disabled    = false;
          btn.textContent = 'Przejdź do kasy \u2192';
          errEl.textContent = 'Błąd: ' + err.message;
          errEl.hidden = false;
        });
    });
  })();
</script>

<style>
  .order-box {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Main book summary ── */
  .order-summary {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .cover-img    { width: 100px; height: auto; border-radius: 4px; box-shadow: 0 2px 10px rgba(53,141,194,.2); flex-shrink: 0; }
  .order-info h2 { font-size: 1.3rem; margin-bottom: .3rem; }
  .price         { font-size: 1.6rem; font-weight: 700; color: var(--clr-accent); }
  .price-note    { font-size: .8rem; color: var(--clr-muted); margin-top: .2rem; }
  .order-hints {
    list-style: none;
    margin: .6rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .order-hints li { font-size: .78rem; color: var(--clr-muted); }

  /* ── Add-ons ── */
  .addons-section {
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .addons-section h3 { font-size: 1.1rem; margin-bottom: .35rem; }
  .addons-desc  { font-size: .88rem; color: var(--clr-muted); margin-bottom: 1rem; }
  .other-projects-link { display: block; text-align: center; font-size: .88rem; color: var(--clr-accent); text-decoration: none; margin-top: .9rem; }
  .other-projects-link:hover { text-decoration: underline; }

  .addons-grid  {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: .7rem;
  }

  .addon-card {
    position: relative;
    border: 2px solid var(--clr-border);
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .15s, box-shadow .15s;
    user-select: none;
  }
  .addon-card:hover { border-color: var(--clr-accent-lt); }
  .addon-card:has(input:checked) {
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 3px rgba(53,141,194,.15);
  }

  /* Hide the real checkbox — card is the interactive element */
  .addon-cb { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }

  /* Custom checkmark bubble */
  .addon-check {
    position: absolute;
    top: .35rem; right: .35rem;
    width: 1.25rem; height: 1.25rem;
    background: rgba(255,255,255,.9);
    border: 2px solid #bbb;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .68rem;
    color: transparent;
    transition: background .15s, border-color .15s, color .15s;
    z-index: 1;
    line-height: 1;
  }
  .addon-card:has(input:checked) .addon-check {
    background: var(--clr-accent);
    border-color: var(--clr-accent);
    color: #fff;
  }

  .addon-cover { width: 100%; height: auto; display: block; border-radius: 0; box-shadow: none; width: auto; }
  .addon-info  { padding: .4rem .5rem .55rem; display: flex; flex-direction: column; gap: .1rem; }
  .addon-title { font-size: .72rem; font-weight: 600; line-height: 1.3; color: var(--clr-text); }
  .addon-price { font-size: .72rem; font-weight: 700; color: var(--clr-accent); }

  /* ── Payment ── */
  .payment-section {
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.8rem;
  }
  .payment-section h3 { font-size: 1.2rem; margin-bottom: .7rem; }
  .payment-desc { color: var(--clr-muted); margin-bottom: 1rem; font-size: .95rem; }
  .payment-methods {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .4rem;
    margin-bottom: 1.5rem;
    font-size: .95rem;
  }
  .pm-logo { height: 24px; width: auto; vertical-align: middle; display: inline-block; }

  /* ── Consents ── */
  .consent-group {
    background: #f8f9fa;
    border: 1px solid var(--clr-border);
    border-radius: 6px;
    padding: .9rem 1rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: .55rem;
  }
  .consent-label {
    display: flex;
    gap: .55rem;
    align-items: flex-start;
    cursor: pointer;
    font-size: .88rem;
    color: var(--clr-text);
    line-height: 1.4;
  }
  .consent-label input[type="checkbox"] {
    margin-top: .15rem;
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    accent-color: var(--clr-accent);
    cursor: pointer;
  }
  .consent-label a { color: var(--clr-accent); text-decoration: underline; }
  .consent-required { color: #c0392b; font-weight: 700; }
  .consent-optional { color: var(--clr-muted); font-style: italic; }
  .newsletter-note { font-size: .78rem; color: var(--clr-muted); margin-top: .1rem; padding-left: 1.45rem; }

  /* ── Shipping method selector ── */
  .shipping-method-group {
    background: #f8f9fa;
    border: 1px solid var(--clr-border);
    border-radius: 6px;
    padding: .9rem 1rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }
  .shipping-method-title {
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--clr-muted);
    margin-bottom: .25rem;
  }
  .shipping-option-label {
    display: flex;
    align-items: flex-start;
    gap: .65rem;
    cursor: pointer;
    padding: .4rem .5rem;
    border-radius: 5px;
    transition: background .12s;
  }
  .shipping-option-label:hover { background: #edf2f7; }
  .shipping-option-label input[type="radio"] {
    margin-top: .22rem;
    flex-shrink: 0;
    accent-color: var(--clr-accent);
    cursor: pointer;
  }
  .shipping-option-content { display: flex; flex-direction: column; gap: .05rem; }
  .shipping-option-name { font-size: .9rem; font-weight: 600; color: var(--clr-text); }
  .shipping-option-note { font-size: .78rem; color: var(--clr-muted); }
  .paczkomat-picker {
    margin: .15rem 0 .25rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .btn-pick-paczkomat {
    font-size: .85rem;
    padding: .4rem .9rem;
    background: var(--clr-accent);
    color: #fff;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    align-self: flex-start;
    transition: background .15s;
  }
  .btn-pick-paczkomat:hover { background: #2474a0; }
  .selected-paczkomat {
    background: #e4f3fa;
    border: 1px solid #b8dff5;
    border-radius: 5px;
    padding: .5rem .75rem;
    display: flex;
    align-items: flex-start;
    gap: .5rem;
  }
  .paczkomat-icon { font-size: 1rem; flex-shrink: 0; }
  .paczkomat-name    { font-size: .88rem; font-weight: 700; color: var(--clr-text); display: block; }
  .paczkomat-address { font-size: .78rem; color: var(--clr-muted); display: block; }

  .btn-order {
    display: block;
    width: 100%;
    text-align: center;
    font-size: 1.1rem;
    padding: 1rem;
    background: #2ea44f;
    cursor: pointer;
    border: none;
  }
  .btn-order:hover:not(:disabled) { background: #22813d; }
  .btn-order:disabled { opacity: .6; cursor: not-allowed; transform: none; }

  .checkout-error {
    color: #c0392b;
    font-size: .85rem;
    text-align: center;
    margin-top: .5rem;
  }
  .secure-note { text-align: center; font-size: .8rem; color: var(--clr-muted); margin-top: .7rem; }

  /* ── Shipping ── */
  .shipping-info { background: #e4f3fa; border-radius: 8px; padding: 1.5rem; }
  .shipping-info h3 { font-size: 1.1rem; margin-bottom: .9rem; }
  .shipping-tier-label {
    font-size: .8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .05em; color: var(--clr-accent); margin: 1rem 0 .3rem;
  }
  .shipping-tier-label:first-of-type { margin-top: 0; }
  .shipping-info table { width: 100%; border-collapse: collapse; margin-bottom: .4rem; }
  .shipping-info td { padding: .3rem 0; font-size: .9rem; border-bottom: 1px solid var(--clr-border); }
  .shipping-info td:last-child { text-align: right; font-weight: 600; }
