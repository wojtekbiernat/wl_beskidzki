---
import Layout from '../layouts/Layout.astro';

// ── Server endpoint ───────────────────────────────────────────────────────────
const SERVER_CHECKOUT_URL = import.meta.env.PUBLIC_SERVER_BASE + '/checkout.php';

// ── Main book ─────────────────────────────────────────────────────────────────
const MAIN_BOOK = {
  id:      'wl',
  product: 'WL',
  cover:   'BookCover.jpg',
  title:   'Książeczka odznaki Beskidzki Włóczykij',
  price:   '43 zł',
};

// ── Badges ────────────────────────────────────────────────────────────────────
const BADGES = [
  { id: 'wl-braz',   product: 'WL_BRAZ',   cover: 'BRAZ.png',   title: 'Odznaka brązowa', price: '35 zł' },
  { id: 'wl-srebro', product: 'WL_SREBRO', cover: 'SREBRO.png', title: 'Odznaka srebrna', price: '35 zł' },
  { id: 'wl-zlota',  product: 'WL_ZLOTA',  cover: 'ZLOTO.png',  title: 'Odznaka złota',   price: '35 zł' },
];

// ── Extra books ───────────────────────────────────────────────────────────────
// Set active: false on any item to hide it from the order page
const EXTRA_BOOKS = [
  { id: 'kws',  product: 'KWS',  active: true,  cover: 'KWS_Cover.jpg',            title: 'Korona Woj. Śląskiego',       price: '20 zł' },
  { id: 'ggmf', product: 'GGMF', active: true,  cover: 'GGMF_Cover.jpg',          title: 'Gł. Grzbiet Małej Fatry',    price: '15 zł' },
  { id: 'ggwf', product: 'GGWF', active: true,  cover: 'GGWF_Cover.jpg',          title: 'Gł. Grzbiet Wielkiej Fatry', price: '15 zł' },
  { id: 'ggnt', product: 'GGNT', active: true,  cover: 'GGNT_Cover.jpg',          title: 'Gł. Grzbiet Niżnych Tatr',   price: '15 zł' },
  { id: 'kw',   product: 'KW',   active: true, cover: 'KORONA_WEGIER_Cover.jpg', title: 'Korona Wzgórz i Gór Węgier', price: '25 zł' },
];
const ACTIVE_EXTRA_BOOKS = EXTRA_BOOKS.filter(b => b.active);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
  title="Przystąp"
  description="Przystąp do projektu Beskidzki Włóczykij — zamów książeczkę, odznakę i zgłoś swoje szczyty."
>

  <div class="page-header">
    <div class="container">
      <h1>Przystąp do projektu</h1>
      <p>Wybierz produkty i rozpocznij przygodę</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container">
      <div class="order-box">

        <!-- ── Section 1: Main book ─────────────────────────────────────── -->
        <div class="order-summary">
          <img src={`${base}img/${MAIN_BOOK.cover}`} alt={MAIN_BOOK.title} class="cover-img" />
          <div class="order-info">
            <h2>{MAIN_BOOK.title}</h2>
            <p class="price">{MAIN_BOOK.price}</p>
            <p class="price-note">Cena nie zawiera kosztów wysyłki.</p>
            <label class="book-opt-label">
              <input type="checkbox" id="cb-mainbook" class="addon-cb" value={MAIN_BOOK.product} />
              <span>Dodaj do zamówienia</span>
            </label>
            <div class="qty-section" id="mainbook-qty" hidden>
              <div class="qty-row">
                <span class="qty-label">Liczba egzemplarzy:</span>
                <div class="qty-stepper">
                  <button type="button" class="qty-btn addon-qty-btn" id="qty-minus" data-dir="-1" aria-label="Mniej">&#x2212;</button>
                  <span id="qty-display" class="qty-display addon-qty-val">1</span>
                  <button type="button" class="qty-btn addon-qty-btn" id="qty-plus" data-dir="1" aria-label="Więcej">+</button>
                </div>
              </div>
            </div>
            <ul class="order-hints">
              <li>Zniżki naliczane są automatycznie</li>
              <li>Kod rabatowy możesz dodać przy kasie</li>
            </ul>
          </div>
        </div>

        <!-- ── Section 2: Badges ─────────────────────────────────────────── -->
        <div class="order-section">
          <h3 class="section-title">🏅 Odznaki</h3>
          <p class="section-desc">Kupienie odznaki wymaga kodu przyznawanego przez weryfikatora.</p>
          <div class="addons-grid badge-grid">
            {BADGES.map(badge => (
              <label class="addon-card badge-card" for={`addon-${badge.id}`}>
                <input type="checkbox" id={`addon-${badge.id}`} class="addon-cb" value={badge.product} />
                <div class="addon-check">✓</div>
                <img src={`${base}img/${badge.cover}`} alt={badge.title} class="addon-cover" />
                <div class="addon-info">
                  <span class="addon-title">{badge.title}</span>
                  <span class="addon-price">{badge.price}</span>
                  <div class="badge-code-wrap">
                    <input
                      type="text"
                      class="badge-code-input"
                      data-badge={badge.product}
                      placeholder="Kod weryfikacji"
                      maxlength="8"
                      autocomplete="off"
                      spellcheck="false"
                    />
                  </div>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- ── Section 3: Extra books ────────────────────────────────────── -->
        {ACTIVE_EXTRA_BOOKS.length > 0 && (
          <div class="order-section">
            <h3 class="section-title">📚 Inne książeczki</h3>
            <p class="section-desc">Dołącz do zamówienia publikacje innych projektów górskich i zaoszczędź na wysyłce.</p>
            <div class="addons-grid">
              {ACTIVE_EXTRA_BOOKS.map(book => (
                <label class="addon-card" for={`addon-${book.id}`}>
                  <input type="checkbox" id={`addon-${book.id}`} class="addon-cb" value={book.product} />
                  <div class="addon-check">✓</div>
                  <img src={`${base}img/${book.cover}`} alt={book.title} class="addon-cover" />
                  <div class="addon-info">
                    <span class="addon-title">{book.title}</span>
                    <span class="addon-price">{book.price}</span>
                    <div class="addon-qty-row">
                      <button type="button" class="addon-qty-btn" data-dir="-1">&#x2212;</button>
                      <span class="addon-qty-val">1</span>
                      <button type="button" class="addon-qty-btn" data-dir="1">+</button>
                    </div>
                  </div>
                </label>
              ))}
            </div>
            <a href={`${base}inne-projekty/`} class="other-projects-link">Poznaj inne projekty &rarr;</a>
          </div>
        )}

        <!-- ── Payment ───────────────────────────────────────────────────── -->
        <div class="payment-section">
          <h3>Wybierz sposób płatności</h3>
          <p class="payment-desc">
            Płatność realizowana jest przez <strong>Stripe</strong> &mdash; bezpieczną,
            szyfrowaną bramkę płatniczą. Akceptujemy:
          </p>
          <ul class="payment-methods">
            <li>&#128241; BLIK</li>
            <li><img src={`${base}img/przelewy24.svg`} alt="Przelewy24" class="pm-logo" />Przelewy24</li>
            <li>&#128179; Karta płatnicza</li>
            <li>&#128242; Google Pay / Apple Pay</li>
          </ul>

          <!-- ── Shipping method ──────────────────────────────────────── -->
          <div class="shipping-method-group">
            <p class="shipping-method-title">Sposób dostawy</p>
            <label class="shipping-option-label">
              <input type="radio" name="shipping-method" id="ship-paczkomat" value="paczkomat" />
              <span class="shipping-option-content">
                <span class="shipping-option-name">&#128230; Dostawa do Paczkomatu</span>
                <span class="shipping-option-note">InPost Paczkomat</span>
              </span>
            </label>
            <div id="paczkomat-picker" class="paczkomat-picker" hidden>
              <p class="paczkomat-label">Wpisz numer paczkomatu</p>
              <p class="paczkomat-hint">Jeżeli nie znasz nr. swojego paczkomatu, kliknij „Znajdź paczkomat", sprawdź numer na stronie InPostu, a potem wróć tutaj i wpisz go w polu poniżej.</p>
              <div class="paczkomat-input-row">
                <input type="text" id="paczkomat-input" class="paczkomat-input"
                       placeholder="np. KAT012" maxlength="20" autocomplete="off" />
                <a href="https://inpost.pl/znajdz-paczkomat" target="_blank" rel="noopener" class="find-paczkomat-link">Znajdź paczkomat →</a>
              </div>
            </div>
            <label class="shipping-option-label">
              <input type="radio" name="shipping-method" id="ship-adres" value="adres" />
              <span class="shipping-option-content">
                <span class="shipping-option-name">&#127968; Dostawa na adres</span>
                <span class="shipping-option-note">Poprosimy Ci&#281; o adres w kolejnym kroku</span>
              </span>
            </label>
          </div>

          <div class="consent-group">
            <label class="consent-label">
              <input type="checkbox" id="cb-regulamin" />
              <span>Zapoznałem/am się z <a href={`${base}regulamin/regulamin-sklepu/`} target="_blank" rel="noopener">Regulaminem sklepu</a> i <a href={`${base}regulamin/polityka-prywatnosci/`} target="_blank" rel="noopener">Polityką prywatności</a> i akceptuję ich postanowienia. <span class="consent-required">*</span></span>
            </label>
            <label class="consent-label">
              <input type="checkbox" id="cb-newsletter" />
              <span>Chcę otrzymywać newsletter z informacjami o projekcie „Beskidzki Włóczykij", nowych publikacjach i aktualnościach. Wiem, że zgodę mogę wycofać w każdej chwili. <span class="consent-optional">(opcjonalne)</span></span>
            </label>
            <p class="newsletter-note">Newsletter wysyłamy wyłącznie od czasu do czasu, z informacjami o projekcie, książeczkach i nowościach. Bez spamu.</p>
          </div>
          <button id="checkout-btn" class="btn btn-order" disabled>
            Przejdź do kasy &rarr;
          </button>
          <p id="checkout-error" class="checkout-error" hidden></p>
          <p class="secure-note">&#128274; Płatność chroniona szyfrowaniem SSL/TLS</p>
        </div>

        <!-- ── Shipping ──────────────────────────────────────────────────── -->
        <div class="shipping-info">
          <h3>Koszty wysyłki (z pakowaniem)</h3>

          <p class="shipping-tier-label">1–3 książeczki lub odznaki</p>
          <table>
            <tbody>
              <tr><td>InPost (paczkomat)</td><td>12,50 zł</td></tr>
              <tr><td>DPD (kurier)</td>        <td>16,00 zł</td></tr>
            </tbody>
          </table>

          <p class="shipping-tier-label">4–5 książeczek lub odznak</p>
          <table>
            <tbody>
              <tr><td>InPost (paczkomat)</td><td>17,50 zł</td></tr>
              <tr><td>DPD (kurier)</td>        <td>21,00 zł</td></tr>
            </tbody>
          </table>

          <p class="free-shipping">✅ Powyżej 5 książeczek lub odznak — <strong>wysyłka gratis</strong> (DPD lub InPost)</p>
        </div>

        <!-- ── PTTK ──────────────────────────────────────────────────────── -->
        <div class="pttk-note">
          <h3>Zakup stacjonarny</h3>
          <p>Książeczkę można nabyć osobiście w <strong>PTTK Katowice</strong> w cenie <strong>43 zł</strong>. Dostępność w sprzedaży stacjonarnej może być ograniczona.</p>
        </div>

      </div>
    </div>
  </div>

</Layout>

<script id="checkout-data" type="application/json" set:html={JSON.stringify({
  serverUrl: SERVER_CHECKOUT_URL,
})}></script>

<script is:inline>
  (function () {
    var cfg   = JSON.parse(document.getElementById('checkout-data').textContent);
    var btn   = document.getElementById('checkout-btn');
    var errEl = document.getElementById('checkout-error');
    var cbReg  = document.getElementById('cb-regulamin');
    var cbNews = document.getElementById('cb-newsletter');
    if (!btn) return;

    var shipPaczkomat   = document.getElementById('ship-paczkomat');
    var shipAdres       = document.getElementById('ship-adres');
    var paczkomatPicker = document.getElementById('paczkomat-picker');
    var paczkomatInput  = document.getElementById('paczkomat-input');

    // ── Badge code inputs — prevent click from toggling checkbox ─────────
    document.querySelectorAll('.badge-code-input').forEach(function (inp) {
      inp.addEventListener('click', function (e) { e.stopPropagation(); });
      inp.addEventListener('input', updateBtn);
    });

    // ── Qty steppers (books only — badges have no stepper) ────────────────
    document.querySelectorAll('.addon-qty-btn').forEach(function (qtyBtn) {
      qtyBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var row   = qtyBtn.closest('.addon-qty-row');
        var valEl = row && row.querySelector('.addon-qty-val');
        if (!valEl) return;
        var v = (parseInt(valEl.textContent) || 1) + parseInt(qtyBtn.dataset.dir);
        valEl.textContent = Math.min(20, Math.max(1, v));
      });
    });

    // Main book checkbox — show/hide qty stepper
    var cbMainBook   = document.getElementById('cb-mainbook');
    var mainBookQty  = document.getElementById('mainbook-qty');
    var qtyDisplay   = document.getElementById('qty-display');
    if (cbMainBook) {
      cbMainBook.addEventListener('change', function () {
        mainBookQty.hidden = !cbMainBook.checked;
        if (!cbMainBook.checked && qtyDisplay) qtyDisplay.textContent = '1';
        updateBtn();
      });
    }

    // Reset qty to 1 and re-check button state on uncheck (addon cards)
    document.querySelectorAll('.addon-cb').forEach(function (cb) {
      cb.addEventListener('change', function () {
        if (!cb.checked) {
          var valEl = cb.closest('.addon-card') && cb.closest('.addon-card').querySelector('.addon-qty-val');
          if (valEl) valEl.textContent = '1';
        }
        updateBtn();
      });
    });

    // ── Readiness checks ──────────────────────────────────────────────────
    function hasItems() {
      return document.querySelectorAll('.addon-cb:checked').length > 0;
    }
    function badgeCodesValid() {
      var ok = true;
      document.querySelectorAll('.badge-card').forEach(function (card) {
        var cb    = card.querySelector('.addon-cb');
        var input = card.querySelector('.badge-code-input');
        if (cb && cb.checked && input && !input.value.trim()) ok = false;
      });
      return ok;
    }
    function isShippingReady() {
      if (shipAdres && shipAdres.checked) return true;
      if (shipPaczkomat && shipPaczkomat.checked && paczkomatInput && paczkomatInput.value.trim()) return true;
      return false;
    }
    function updateBtn() {
      btn.disabled = !(hasItems() && cbReg && cbReg.checked && isShippingReady() && badgeCodesValid());
    }

    if (cbReg)          cbReg.addEventListener('change', updateBtn);
    if (paczkomatInput) paczkomatInput.addEventListener('input', updateBtn);

    if (shipPaczkomat) shipPaczkomat.addEventListener('change', function () {
      paczkomatPicker.hidden = !shipPaczkomat.checked;
      updateBtn();
    });
    if (shipAdres) shipAdres.addEventListener('change', function () {
      if (shipAdres.checked) paczkomatPicker.hidden = true;
      updateBtn();
    });

    // ── Checkout ──────────────────────────────────────────────────────────
    btn.addEventListener('click', function () {
      var items = [];
      document.querySelectorAll('.addon-cb:checked').forEach(function (cb) {
        var card  = cb.closest('.addon-card');
        var valEl = card && card.querySelector('.addon-qty-val');
        var codeEl = card && card.querySelector('.badge-code-input');
        var item  = { product: cb.value, quantity: valEl ? (parseInt(valEl.textContent) || 1) : 1 };
        if (codeEl) item.badge_code = codeEl.value.trim().toLowerCase();
        items.push(item);
      });

      btn.disabled    = true;
      btn.textContent = 'Ładowanie\u2026';
      errEl.hidden    = true;

      fetch(cfg.serverUrl, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          items:           items,
          newsletter:      !!(cbNews && cbNews.checked),
          regulamin:       true,
          shipping_method: shipPaczkomat && shipPaczkomat.checked ? 'paczkomat' : 'adres',
          paczkomat_id:    paczkomatInput ? paczkomatInput.value.trim() : '',
        }),
      })
        .then(function (res) { return res.json(); })
        .then(function (json) {
          if (json.url) {
            window.location.href = json.url;
          } else {
            throw new Error(json.error || 'Nieznany błąd');
          }
        })
        .catch(function (err) {
          btn.disabled    = false;
          btn.textContent = 'Przejdź do kasy \u2192';
          errEl.textContent = 'Błąd: ' + err.message;
          errEl.hidden = false;
        });
    });
  })();
</script>

<style>
  .order-box {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Main book summary ── */
  .order-summary {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .cover-img  { width: 100px; height: auto; border-radius: 4px; box-shadow: 0 2px 10px rgba(53,141,194,.2); flex-shrink: 0; }
  .order-info h2 { font-size: 1.3rem; margin-bottom: .3rem; }
  .price      { font-size: 1.6rem; font-weight: 700; color: var(--clr-accent); }
  .price-note { font-size: .8rem; color: var(--clr-muted); margin-top: .2rem; }
  .book-opt-label {
    display: inline-flex; align-items: center; gap: .6rem;
    margin-top: .9rem; cursor: pointer;
    font-size: 1rem; font-weight: 700; color: #fff;
    background: var(--clr-accent); border-radius: 6px;
    padding: .5rem .9rem;
    transition: background .15s;
  }
  .book-opt-label:has(input:checked) { background: #22813d; }
  .book-opt-label input { accent-color: #fff; width: 16px; height: 16px; cursor: pointer; flex-shrink: 0; }
  .qty-section { margin-top: .6rem; }
  .qty-row { display: flex; align-items: center; gap: .75rem; }
  .qty-label { font-size: .88rem; color: var(--clr-muted); }
  .qty-stepper { display: flex; align-items: center; border: 1px solid var(--clr-border); border-radius: 6px; overflow: hidden; }
  .qty-btn { background: #f5f7fa; border: none; width: 2rem; height: 2rem; font-size: 1.1rem; cursor: pointer; color: var(--clr-text); display: flex; align-items: center; justify-content: center; transition: background .12s; user-select: none; }
  .qty-btn:hover { background: #e2e8f0; }
  .qty-display { font-size: 1rem; font-weight: 700; min-width: 2.2rem; text-align: center; color: var(--clr-text); padding: 0 .25rem; }
  .order-hints { list-style: none; margin: .6rem 0 0; padding: 0; display: flex; flex-direction: column; gap: .25rem; }
  .order-hints li { font-size: .78rem; color: var(--clr-muted); }

  /* ── Order sections ── */
  .order-section {
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .section-title { font-size: 1.1rem; margin-bottom: .35rem; }
  .section-desc  { font-size: .88rem; color: var(--clr-muted); margin-bottom: 1rem; }
  .other-projects-link { display: block; text-align: center; font-size: .88rem; color: var(--clr-accent); text-decoration: none; margin-top: .9rem; }
  .other-projects-link:hover { text-decoration: underline; }

  /* ── Addon grid & cards ── */
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
    gap: .7rem;
  }
  .addon-card {
    position: relative;
    border: 2px solid var(--clr-border);
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .15s, box-shadow .15s;
    user-select: none;
  }
  .addon-card:hover { border-color: var(--clr-accent-lt); }
  .addon-card:has(input:checked) {
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 3px rgba(53,141,194,.15);
  }
  .addon-cb { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }
  .addon-check {
    position: absolute;
    top: .35rem; right: .35rem;
    width: 1.25rem; height: 1.25rem;
    background: rgba(255,255,255,.9);
    border: 2px solid #bbb;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .68rem;
    color: transparent;
    transition: background .15s, border-color .15s, color .15s;
    z-index: 1;
    line-height: 1;
  }
  .addon-card:has(input:checked) .addon-check {
    background: var(--clr-accent);
    border-color: var(--clr-accent);
    color: #fff;
  }
  .addon-cover { width: 100%; height: auto; display: block; }
  .addon-info  { padding: .4rem .5rem .55rem; display: flex; flex-direction: column; gap: .1rem; }
  .addon-title { font-size: .72rem; font-weight: 600; line-height: 1.3; color: var(--clr-text); }
  .addon-price { font-size: .72rem; font-weight: 700; color: var(--clr-accent); }
  .addon-qty-row { display: none; align-items: center; margin-top: .3rem; border: 1px solid var(--clr-border); border-radius: 5px; overflow: hidden; align-self: flex-start; }
  .addon-card:has(input:checked) .addon-qty-row { display: flex; }
  .addon-qty-btn { background: #f5f7fa; border: none; width: 1.6rem; height: 1.6rem; font-size: .9rem; cursor: pointer; color: var(--clr-text); display: flex; align-items: center; justify-content: center; transition: background .12s; user-select: none; }
  .addon-qty-btn:hover { background: #e2e8f0; }
  .addon-qty-val { font-size: .82rem; font-weight: 700; min-width: 1.6rem; text-align: center; }

  /* ── Badge code input ── */
  .badge-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
  .badge-grid .addon-title { font-size: .8rem; }
  .badge-grid .addon-price { font-size: .8rem; }

  .badge-code-wrap { display: none; margin-top: .4rem; }
  .badge-card:has(input.addon-cb:checked) .badge-code-wrap { display: block; }
  .badge-code-input {
    font-size: .72rem; font-family: monospace; letter-spacing: .05em;
    width: 100%; padding: .3rem .4rem;
    border: 1px solid var(--clr-accent); border-radius: 4px;
