---
import Layout from '../../layouts/Layout.astro';
import peaksData from '../../data/peaks.json';

type Trail = 'on' | 'near' | 'off';
type Country = 'PL' | 'CZ' | 'SK' | 'UA';

interface Peak {
  id: number; lp: number; country: Country;
  name: string; region: string; height: number;
  trail: Trail; highestInRegion: string;
  lat: number | null; lng: number | null;
}

const peaks = peaksData as Peak[];
const peaksWithCoords = peaks.filter(p => p.lat !== null);

const flag: Record<Country, string> = { PL: '🇵🇱', CZ: '🇨🇿', SK: '🇸🇰', UA: '🇺🇦' };
const trailLabel: Record<Trail, string> = { on: 'na szlaku', near: 'blisko szlaku', off: 'poza szlakiem' };

// Safe JSON for inline <script> tag
const coordsJson = JSON.stringify(
  peaksWithCoords.map(p => ({ id: p.id, name: p.name, lat: p.lat, lng: p.lng }))
).replace(/<\/script>/gi, '<\\/script>');
---

<!-- Leaflet CSS injected into <head> via Layout slot -->
<link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<Layout
  title="Wykaz Szczytów"
  description="Wykaz 150 szczytów objętych Odznaką Beskidzkiego Włóczykija — Polska, Czechy, Słowacja, Ukraina."
>

  <div class="page-header">
    <div class="container">
      <h1>Wykaz Szczytów</h1>
      <p>150 szczytów w czterech krajach — Polska, Czechy, Słowacja, Ukraina</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container">

      <!-- ── ODZNAKA / POZIOMY ── -->
      <section id="wykaz" class="peaks-section peaks-section--first">
        <h2>Odznaka</h2>
        <p>
          Odznaka obejmuje łącznie <strong>150 szczytów</strong> w czterech krajach. Zdobywanie
          odbywa się w dowolnej kolejności, bez limitu czasowego.
        </p>
        <div class="levels-grid">
          <div class="level bronze">
            <span class="level-name">🥉 Brązowa</span>
            <span class="level-req">50 dowolnych szczytów</span>
          </div>
          <div class="level silver">
            <span class="level-name">🥈 Srebrna</span>
            <span class="level-req">100 szczytów łącznie</span>
          </div>
          <div class="level gold">
            <span class="level-name">🥇 Złota</span>
            <span class="level-req">Wszystkie 150 szczytów</span>
          </div>
        </div>
        <div class="trail-legend">
          <strong>Dostęp do szczytu:</strong>
          <span class="badge on">na szlaku</span>
          <span class="badge near">blisko szlaku</span>
          <span class="badge off">poza szlakiem</span>
        </div>
      </section>

      <!-- ── MAPA + TABELA ── -->
      <section id="szczyty" class="peaks-section">
        <p class="ua-note">
          ⚠️ Zdobywanie szczytów leżących na terenie Ukrainy objętej trwającymi działaniami
          wojennymi nie jest obowiązkowe, a autorzy projektu odradzają podejmowanie takiej
          aktywności.
        </p>

        <div class="peaks-layout">

          <!-- Left: sticky Leaflet map -->
          <div id="peaks-map" class="map-embed"></div>

          <!-- Right: unified table -->
          <div class="table-wrap">
            <table class="peaks-table" id="peaks-table">
              <thead>
                <tr>
                  <th>Lp.</th>
                  <th>Kraj</th>
                  <th>Szczyt</th>
                  <th>Mezoregion</th>
                  <th>Wys.&nbsp;(m)</th>
                  <th>Szlak</th>
                  <th>Najwyższy szczyt mezoregionu</th>
                </tr>
              </thead>
              <tbody>
                {peaks.map(peak => (
                  <tr data-peak-id={peak.lat !== null ? String(peak.id) : undefined}>
                    <td>{peak.lp}</td>
                    <td class="td-flag">{flag[peak.country]}</td>
                    <td>
                      {peak.name}
                      {peak.lat !== null && (
                        <a
                          href={`https://mapy.com/en/turisticka?x=${peak.lng}&y=${peak.lat}&z=15&source=coor&id=${peak.lng},${peak.lat}`}
                          class="map-link"
                          target="_blank"
                          rel="noopener"
                          title="Pokaż na mapie"
                        >📍</a>
                      )}
                    </td>
                    <td>{peak.region}</td>
                    <td>{peak.height}</td>
                    <td><span class={`badge ${peak.trail}`}>{trailLabel[peak.trail]}</span></td>
                    <td>{peak.highestInRegion}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div><!-- /.table-wrap -->

        </div><!-- /.peaks-layout -->
      </section>

    </div>
  </div>

</Layout>

<!-- Peak coordinates for Leaflet (only peaks that have coords) -->
<script id="peaks-data" type="application/json" set:html={coordsJson}></script>

<!-- Leaflet JS (CDN, synchronous) -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  function initMap() {
    var el = document.getElementById('peaks-map');
    if (!el || typeof L === 'undefined') return;

    var rawData = document.getElementById('peaks-data');
    if (!rawData) return;
    var peaks = JSON.parse(rawData.textContent || '[]');

    var map = L.map('peaks-map');

    L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
      maxZoom: 17,
      attribution:
        'Map data: &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, ' +
        '<a href="http://viewfinderpanoramas.org">SRTM</a> | ' +
        'Map style: &copy; <a href="https://opentopomap.org">OpenTopoMap</a> (CC-BY-SA)',
    }).addTo(map);

    function makeIcon(color, size) {
      return L.divIcon({
        className: '',
        html:
          '<div style="width:' + size + 'px;height:' + size + 'px;' +
          'background:' + color + ';border:2px solid #fff;border-radius:50%;' +
          'box-shadow:0 2px 5px rgba(0,0,0,.45)"></div>',
        iconSize:    [size, size],
        iconAnchor:  [size / 2, size / 2],
        popupAnchor: [0, -(size / 2 + 4)],
      });
    }

    var normalIcon = makeIcon('#358dc2', 12);
    var activeIcon = makeIcon('#e74c3c', 18);

    var markerById = {};
    var peakById   = {};

    peaks.forEach(function (peak) {
      peakById[peak.id] = peak;
      markerById[peak.id] = L.marker([peak.lat, peak.lng], { icon: normalIcon })
        .addTo(map)
        .bindPopup('<strong>' + peak.name + '</strong>');
    });

    // Fit map to all markers, or fall back to Beskydy centre
    var allMarkers = Object.values(markerById);
    if (allMarkers.length > 0) {
      map.fitBounds(L.featureGroup(allMarkers).getBounds().pad(0.15));
    } else {
      map.setView([49.47, 18.35], 8);
    }

    // Table-row ↔ marker interaction
    var activeId = null;
    var rows = document.querySelectorAll('#peaks-table tbody tr[data-peak-id]');

    rows.forEach(function (row) {
      var id = parseInt(row.dataset.peakId, 10);

      // Hover preview (desktop)
      row.addEventListener('mouseenter', function () {
        if (activeId === id) return;
        if (markerById[id]) {
          markerById[id].setIcon(activeIcon);
          markerById[id].openPopup();
          map.panTo([peakById[id].lat, peakById[id].lng], { animate: true, duration: 0.3 });
        }
      });
      row.addEventListener('mouseleave', function () {
        if (activeId === id) return;
        if (markerById[id]) {
          markerById[id].setIcon(normalIcon);
          markerById[id].closePopup();
        }
      });

      // Click / tap — lock / unlock selection
      row.addEventListener('click', function () {
        var prev = activeId;
        if (prev !== null && markerById[prev]) {
          markerById[prev].setIcon(normalIcon);
          markerById[prev].closePopup();
          var prevRow = document.querySelector('#peaks-table tbody tr[data-peak-id="' + prev + '"]');
          if (prevRow) prevRow.classList.remove('row-active');
        }
        if (prev === id) {
          activeId = null;
        } else {
          activeId = id;
          if (markerById[id]) {
            markerById[id].setIcon(activeIcon);
            markerById[id].openPopup();
            map.panTo([peakById[id].lat, peakById[id].lng], { animate: true, duration: 0.3 });
          }
          row.classList.add('row-active');
        }
      });
    });
  }

  if (document.readyState !== 'loading') {
    initMap();
  } else {
    document.addEventListener('DOMContentLoaded', initMap);
  }
</script>

<style>
  /* ── Layout: map left + table right ── */
  .peaks-layout {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 1rem;
    align-items: start;
  }
  .peaks-layout #peaks-map {
    margin: 0;
    height: 560px;
    position: sticky;
    top: 68px;
  }
  .peaks-layout .table-wrap { overflow-x: auto; }

  @media (max-width: 900px) {
    .peaks-layout {
      grid-template-columns: 1fr;
    }
    .peaks-layout #peaks-map {
      position: static;
      height: 280px;
    }
  }

  /* ── Sections ── */
  .peaks-section {
    margin-bottom: 3rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--clr-border);
  }
  .peaks-section--first { border-top: none; }
  .peaks-section h2  { font-size: 1.6rem; margin-bottom: .8rem; }
  .peaks-section p   { color: var(--clr-muted); margin-bottom: 1.1rem; line-height: 1.8; }

  /* ── Levels grid ── */
  .levels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.2rem 0;
  }
  .level {
    border-radius: 8px;
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    border: 2px solid;
  }
  .level.bronze { background: #fdf3e3; border-color: #cd7f32; }
  .level.silver { background: #f4f4f5; border-color: #a8a9ad; }
  .level.gold   { background: #fefbe6; border-color: #d4a017; }
  .level-name   { font-weight: 700; font-size: .95rem; }
  .level-req    { font-size: .85rem; color: var(--clr-muted); }

  /* ── Trail legend ── */
  .trail-legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .6rem;
    margin-top: .8rem;
    font-size: .88rem;
    color: var(--clr-muted);
  }

  /* ── Trail badges ── */
  .badge {
    display: inline-block;
    padding: .15rem .55rem;
    border-radius: 12px;
    font-size: .75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .badge.on   { background: #d4edda; color: #155724; }
  .badge.near { background: #fff3cd; color: #856404; }
  .badge.off  { background: #f8d7da; color: #721c24; }

  /* ── Ukraine warning ── */
  .ua-note {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 6px;
    padding: .8rem 1.1rem;
    font-size: .9rem;
    color: #6d5000 !important;
    margin-bottom: 1.2rem;
  }

  /* ── Map embed container ── */
  .map-embed {
    display: block;
    width: 100%;
    height: 420px;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    margin: .6rem 0 1.2rem;
  }

  /* ── Map pin links ── */
  .map-link {
    font-size: .85em;
    text-decoration: none;
    opacity: .6;
    margin-left: .25em;
    vertical-align: middle;
    transition: opacity .15s;
  }
  .map-link:hover { opacity: 1; }

  /* ── Table ── */
  .table-wrap { overflow-x: auto; }
  .peaks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .85rem;
    min-width: 620px;
  }
  .peaks-table th {
    background: var(--clr-accent);
    color: #fff;
    padding: .55rem .7rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }
  .peaks-table td {
    padding: .4rem .7rem;
    border-bottom: 1px solid var(--clr-border);
    vertical-align: middle;
  }
  .peaks-table tbody tr:nth-child(even) { background: #f0f7fc; }
  .peaks-table tbody tr:hover           { background: #d4eaf6; }
  .peaks-table td:first-child { text-align: center; color: var(--clr-muted); width: 2.5rem; }
  .td-flag { text-align: center !important; font-size: 1.1em; width: 2rem; }

  /* Active row (tap/click on mobile) */
  #peaks-table tbody tr[data-peak-id] { cursor: pointer; }
  #peaks-table tbody tr.row-active {
    background: #afd4ec !important;
    outline: 2px solid #358dc2;
    outline-offset: -2px;
  }

  @media (max-width: 640px) {
    .levels-grid { grid-template-columns: 1fr; }
  }
</style>
