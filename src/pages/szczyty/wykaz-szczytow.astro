<style>
  /* Section quick-nav */
  .section-nav {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2.5rem;
  }
  .section-nav a {
    background: var(--clr-accent);
    color: #fff;
    padding: .35rem .9rem;
    border-radius: 20px;
    text-decoration: none;
    font-size: .85rem;
    font-weight: 600;
    transition: background .2s;
  }
  .section-nav a:hover { background: var(--clr-accent-lt); }

  /* Sections */
  .peaks-section {
    margin-bottom: 3.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--clr-border);
  }
  .peaks-section:first-of-type { border-top: none; }
  .peaks-section h2 { font-size: 1.6rem; margin-bottom: .8rem; }
  .peaks-section p  { color: var(--clr-muted); margin-bottom: 1.1rem; line-height: 1.8; }
  .count { font-size: 1rem; font-weight: 400; color: var(--clr-muted); }

  /* Levels grid */
  .levels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.2rem 0;
  }
  .level {
    border-radius: 8px;
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    border: 2px solid;
  }
  .level.bronze { background: #fdf3e3; border-color: #cd7f32; }
  .level.silver { background: #f4f4f5; border-color: #a8a9ad; }
  .level.gold   { background: #fefbe6; border-color: #d4a017; }
  .level-name   { font-weight: 700; font-size: .95rem; }
  .level-req    { font-size: .85rem; color: var(--clr-muted); }

  /* Trail legend */
  .trail-legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .6rem;
    margin-top: .8rem;
    font-size: .88rem;
    color: var(--clr-muted);
  }

  /* Trail access badges */
  .badge {
    display: inline-block;
    padding: .15rem .55rem;
    border-radius: 12px;
    font-size: .75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .badge.on   { background: #d4edda; color: #155724; }
  .badge.near { background: #fff3cd; color: #856404; }
  .badge.off  { background: #f8d7da; color: #721c24; }

  /* Ukraine warning */
  .ua-note {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 6px;
    padding: .8rem 1.1rem;
    font-size: .9rem;
    color: #6d5000 !important;
    margin-bottom: 1.2rem;
  }

  /* Table */
  .table-wrap { overflow-x: auto; }
  .peaks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .85rem;
    min-width: 600px;
  }
  .peaks-table th {
    background: var(--clr-accent);
    color: #fff;
    padding: .55rem .7rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }
  .peaks-table td {
    padding: .4rem .7rem;
    border-bottom: 1px solid var(--clr-border);
    vertical-align: middle;
  }
  .peaks-table tbody tr:nth-child(even) { background: #f0f7fc; }
  .peaks-table tbody tr:hover { background: #d4eaf6; }
  .peaks-table td:first-child { text-align: center; color: var(--clr-muted); width: 2.5rem; }

  @media (max-width: 640px) {
    .levels-grid { grid-template-columns: 1fr; }
  }
</style>
