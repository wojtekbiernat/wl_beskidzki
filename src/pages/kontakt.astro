---
import Layout from '../layouts/Layout.astro';

const FORM_ENDPOINT = 'https://korunahor.cz/wl_beskidzki/contact.php';
const HCAPTCHA_SITE_KEY = '5128481c-68c4-47ee-9a82-761e67b48fb4';
---

<Layout
  title="Kontakt"
  description="Skontaktuj się z nami w sprawie książki, zamówień lub pytań ogólnych."
>

  <div class="page-header">
    <div class="container">
      <h1>Kontakt</h1>
      <p>Chętnie odpiszemy na Twoje pytania</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container contact-layout">

      <!-- Contact details -->
      <aside class="contact-details">
        <h2>Dane kontaktowe</h2>
        <ul>
          <li>
            <span class="icon">&#9993;</span>
            <div>
              <strong>E-mail</strong><br />
              <a href="mailto:biuro@beskidzkiwloczykij.pl">biuro@beskidzkiwloczykij.pl</a>
            </div>
          </li>
          <li>
            <span class="icon">&#128222;</span>
            <div>
              <strong>Telefon</strong><br />
              <a href="tel:+48508730296">+48 508 730 296</a>
            </div>
          </li>
          <li>
            <span class="icon">&#9200;</span>
            <div>
              <strong>Godziny odpowiedzi</strong><br />
              Pon–Pt, 9:00–17:00
            </div>
          </li>
          <li>
            <span class="icon">&#128100;</span>
            <div>
              <strong>Facebook</strong><br />
              <a href="https://www.facebook.com/profile.php?id=61583667028562" target="_blank" rel="noopener">
                Beskidzki Włóczykij
              </a>
            </div>
          </li>
        </ul>

        <div class="bank-box">
          <h3>Przelew bankowy</h3>
          <p class="bank-label">Odbiorca</p>
          <p class="bank-value">[Imię Nazwisko / Nazwa organizacji]</p>
          <p class="bank-label">Numer konta</p>
          <p class="bank-value bank-iban">64 1020 2498 0000 8302 0412 9482</p>
          <p class="bank-label">Tytuł przelewu</p>
          <p class="bank-value">Odznaka Beskidzki Włóczykij – [Twoje imię i nazwisko]</p>
        </div>

      </aside>

      <!-- Contact form -->
      <section class="contact-form-wrap">
        <h2>Napisz do nas</h2>

        <div id="form-success" class="alert alert-success" hidden>
          Dziękujemy! Wiadomość została wysłana. Odpiszemy wkrótce.
        </div>
        <div id="form-error" class="alert alert-error" hidden>
          Przepraszamy, coś poszło nie tak. Spróbuj ponownie lub napisz bezpośrednio na e-mail.
        </div>

        <form id="contact-form" novalidate>
          <div class="field">
            <label for="name">Imię i nazwisko <span aria-hidden="true">*</span></label>
            <input id="name" name="name" type="text" required autocomplete="name" placeholder="Jan Kowalski" />
          </div>

          <div class="field">
            <label for="email">Adres e-mail <span aria-hidden="true">*</span></label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="jan@example.com" />
          </div>

          <div class="field">
            <label for="subject">Temat</label>
            <select id="subject" name="subject">
              <option value="">-- wybierz --</option>
              <option value="zamowienie">Pytanie o zamówienie</option>
              <option value="ksiazka">Pytanie o książkę</option>
              <option value="wspolpraca">Współpraca / media</option>
              <option value="inne">Inne</option>
            </select>
          </div>

          <div class="field">
            <label for="message">Wiadomość <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required placeholder="Twoja wiadomość..."></textarea>
          </div>

          <!-- hCaptcha widget — loads automatically via hcaptcha.js -->
          <div class="h-captcha" data-sitekey={HCAPTCHA_SITE_KEY}></div>

          <button type="submit" class="btn" id="submit-btn">
            Wyślij wiadomość
          </button>
        </form>
      </section>

    </div>
  </div>

</Layout>

<!-- hCaptcha script -->
<script src="https://js.hcaptcha.com/1/api.js" async defer></script>

<script define:vars={{ FORM_ENDPOINT }}>
  const form      = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successEl = document.getElementById('form-success');
  const errorEl   = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Grab hCaptcha token
    const captchaResponse = document.querySelector('[name="h-captcha-response"]')?.value;
    if (!captchaResponse) {
      alert('Proszę wypełnić captcha.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wysyłanie…';
    successEl.hidden = true;
    errorEl.hidden   = true;

    const payload = {
      name:            form.name.value.trim(),
      email:           form.email.value.trim(),
      subject:         form.subject.value,
      message:         form.message.value.trim(),
      captchaResponse,
    };

    try {
      const res = await fetch(FORM_ENDPOINT, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });

      if (res.ok) {
        form.reset();
        if (window.hcaptcha) window.hcaptcha.reset();
        successEl.hidden = false;
        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch (err) {
      errorEl.hidden = false;
    } finally {
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Wyślij wiadomość';
    }
  });
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .contact-layout { grid-template-columns: 1fr; }
  }

  /* Contact details */
  .contact-details h2 { font-size: 1.2rem; margin-bottom: 1rem; color: var(--clr-accent); }
  .contact-details ul { list-style: none; display: flex; flex-direction: column; gap: 1.2rem; }
  .contact-details li { display: flex; gap: .8rem; align-items: flex-start; }
  .icon { font-size: 1.3rem; line-height: 1.4; flex-shrink: 0; }
  .contact-details a { color: var(--clr-accent-lt); text-decoration: none; }
  .contact-details a:hover { text-decoration: underline; }

  /* Bank transfer box */
  .bank-box {
    margin-top: 1.8rem;
    background: #e4f3fa;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.1rem 1.2rem;
  }
  .bank-box h3 { font-size: 1rem; margin-bottom: .8rem; color: var(--clr-accent); }
  .bank-label  { font-size: .75rem; font-weight: 600; text-transform: uppercase;
                 letter-spacing: .05em; color: var(--clr-muted); margin-top: .6rem; }
  .bank-value  { font-size: .9rem; color: var(--clr-text); word-break: break-all; }
  .bank-iban   { font-family: monospace; font-size: .95rem; letter-spacing: .04em; }

  /* Form */
  .contact-form-wrap h2 { font-size: 1.3rem; margin-bottom: 1.2rem; color: var(--clr-accent); }

  .field { display: flex; flex-direction: column; gap: .3rem; margin-bottom: 1rem; }
  label  { font-size: .9rem; font-weight: 600; }
  label span { color: #c0392b; }

  input, select, textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: .6rem .8rem;
    border: 1px solid var(--clr-border);
    border-radius: 4px;
    background: #fff;
    color: var(--clr-text);
    width: 100%;
    transition: border-color .2s;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 3px rgba(74,55,40,.12);
  }
  textarea { resize: vertical; }

  .h-captcha { margin: 1rem 0; }

  button[type="submit"] { margin-top: .5rem; }
  button:disabled { opacity: .6; cursor: not-allowed; }

  /* Alerts */
  .alert {
    padding: 1rem 1.2rem;
    border-radius: 4px;
    margin-bottom: 1.2rem;
    font-size: .95rem;
  }
  .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
  .alert-error   { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
</style>
