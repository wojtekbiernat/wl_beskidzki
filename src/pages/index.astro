---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Strona główna" description="[PLACEHOLDER: krótki opis książki i wydawnictwa]">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Nowy projekt górski</h1>
          <p class="hero-sub">150 nieoczywistych szczytów, 4 kraje i jedna idea: wędrować po górach szerzej, spokojniej i bardziej po swojemu.</p>
          <div class="hero-cta">
            <a href="/wl_beskidzki/przystap" class="btn">Przystąp teraz</a>
            <a href="/wl_beskidzki/o-projekcie/o-odznace" class="btn btn-outline">Dowiedz się więcej</a>
          </div>
        </div>
        <div class="hero-cover">
          <img src="/wl_beskidzki/img/ThreeBadges.png" alt="Odznaki górskie" class="badges-img" />
        </div>
      </div>
    </div>
  </section>
  <!-- Quote / excerpt -->
  <section class="excerpt content-section">
    <div class="container">
      <blockquote>
        <p>„To nie Ty jesteś w górach, To góry są w Tobie"</p>
        <cite>— John Muir</cite>
      </blockquote>
    </div>
  </section>

  <!-- Patron strip -->
  <section class="patron-strip content-section">
    <div class="container">
      <p class="patron-label">Patron Projektu</p>
      <a href="https://pttk.katowice.pl" target="_blank" rel="noopener">
        <img src="/wl_beskidzki/img/logo-pttk.png" alt="PTTK — Polskie Towarzystwo Turystyczno-Krajoznawcze" class="patron-logo" />
      </a>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="cta-banner">
    <div class="container">
      <h2>Zamów swój egzemplarz już dziś</h2>
      <p>Dostawa na terenie całej Polski. Płatność kartą, BLIK lub Przelewy24.</p>
      <a href="/wl_beskidzki/przystap" class="btn">Przejdź do zamówienia</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    background:
      linear-gradient(rgba(10, 38, 58, .62), rgba(10, 38, 58, .55)),
      url('/wl_beskidzki/img/Front_page_image.jpg') center / cover no-repeat;
    color: #fff;
    padding: 4rem 0;
  }
  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .hero-text { flex: 1; min-width: 260px; }
  .hero-label {
    text-transform: uppercase;
    letter-spacing: .1em;
    font-size: .8rem;
    opacity: .7;
    margin-bottom: .5rem;
  }
  .hero-text h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .hero-sub { opacity: .85; font-size: 1.05rem; margin-bottom: 1.8rem; }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-cover { flex: 0 0 260px; text-align: center; }
  .badges-img {
    width: 100%;
    max-width: 260px;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,.35));
  }

  /* Blurb */
  .blurb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }
  .blurb-item { text-align: center; }
  .blurb-icon { font-size: 2rem; display: block; margin-bottom: .5rem; }
  .blurb-item h3 { margin-bottom: .4rem; font-size: 1.1rem; }
  .blurb-item p  { font-size: .95rem; color: var(--clr-muted); }

  /* Excerpt / quote */
  blockquote {
    border-left: 4px solid var(--clr-accent);
    padding: 1.2rem 2rem;
    max-width: 680px;
    margin: 0 auto;
    font-family: var(--font-serif);
    font-size: 1.15rem;
  }
  blockquote p    { margin-bottom: .6rem; }
  blockquote cite { font-style: normal; font-size: .9rem; color: var(--clr-muted); }

  /* Patron strip */
  .patron-strip { text-align: center; padding: 2.5rem 0; }
  .patron-label {
    text-transform: uppercase;
    letter-spacing: .1em;
    font-size: .75rem;
    color: var(--clr-muted);
    margin-bottom: 1rem;
  }
  .patron-logo {
    height: 120px;
    width: auto;
    opacity: .85;
    transition: opacity .2s;
  }
  .patron-logo:hover { opacity: 1; }

  /* CTA banner */
  .cta-banner {
    background: var(--clr-accent);
    color: #fff;
    padding: 3rem 0;
    text-align: center;
  }
  .cta-banner h2 { font-size: 1.7rem; margin-bottom: .6rem; }
  .cta-banner p  { opacity: .85; margin-bottom: 1.5rem; }
</style>
