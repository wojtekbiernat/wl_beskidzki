---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Szczyty"
  description="Wykaz szczytów objętych Odznaką Włóczykija Beskidzkiego — Polska, Czechy, Słowacja, Ukraina."
>

  <div class="page-header">
    <div class="container">
      <h1>Szczyty</h1>
      <p>Kompletny wykaz szczytów Odznaki Włóczykija Beskidzkiego</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container">

      <!-- Quick nav anchors -->
      <nav class="section-nav" aria-label="Nawigacja po sekcjach">
        <a href="#geografia">Geografia</a>
        <a href="#wykaz">Wykaz Szczytów</a>
        <a href="#pl">Polska</a>
        <a href="#cz">Czechy</a>
        <a href="#sk">Słowacja</a>
        <a href="#ua">Ukraina</a>
      </nav>

      <!-- Geografia -->
      <section id="geografia" class="peaks-section">
        <h2>Geografia</h2>
        <p>
          [PLACEHOLDER: Ogólny opis geograficzny Beskidów — zasięg pasm, charakterystyczne cechy
          terenu, podział na grupy górskie.]
        </p>
        <p>
          [PLACEHOLDER: Informacje o granicach przebiegających przez Beskidy oraz o tym,
          jak przekładają się one na szczyty objęte odznaką.]
        </p>
      </section>

      <!-- Wykaz Szczytów -->
      <section id="wykaz" class="peaks-section">
        <h2>Wykaz Szczytów</h2>
        <p>
          [PLACEHOLDER: Wprowadzenie do wykazu — ile szczytów łącznie, jak są pogrupowane,
          jakie są kryteria włączenia szczytu do listy.]
        </p>
      </section>

      <!-- Polska -->
      <section id="pl" class="peaks-section">
        <h2>&#127987;&#65039; Polska</h2>
        <p>[PLACEHOLDER: Opis polskiej części Beskidów objętej odznaką.]</p>
        <table class="peaks-table">
          <thead>
            <tr>
              <th>Lp.</th>
              <th>Nazwa szczytu</th>
              <th>Wysokość (m n.p.m.)</th>
              <th>Pasmo</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>1</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
            <tr><td>2</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Czechy -->
      <section id="cz" class="peaks-section">
