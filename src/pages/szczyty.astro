              <th>Nazwa szczytu</th>
              <th>Wysokość (m n.p.m.)</th>
              <th>Pasmo</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>1</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
            <tr><td>2</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Słowacja -->
      <section id="sk" class="peaks-section">
        <h2>&#127820; Słowacja</h2>
        <p>[PLACEHOLDER: Opis słowackiej części Beskidów objętej odznaką.]</p>
        <table class="peaks-table">
          <thead>
            <tr>
              <th>Lp.</th>
              <th>Nazwa szczytu</th>
              <th>Wysokość (m n.p.m.)</th>
              <th>Pasmo</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>1</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
            <tr><td>2</td><td>[PLACEHOLDER]</td><td>—</td><td>—</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Ukraina -->
      <section id="ua" class="peaks-section">
        <h2>&#127822; Ukraina</h2>
        <p>[PLACEHOLDER: Opis ukraińskiej części Beskidów objętej odznaką.]</p>
        <table class="peaks-table">
          <thead>
            <tr>
              <th>Lp.</th>
              <th>Nazwa szczytu</th>
              <th>Wysokość (m n.p.m.)</th>
