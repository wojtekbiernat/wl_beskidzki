    </div>
  </div>

</Layout>

<style>
  /* Section quick-nav */
  .section-nav {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2.5rem;
  }
  .section-nav a {
    background: var(--clr-accent);
    color: #fff;
    padding: .35rem .9rem;
    border-radius: 20px;
    text-decoration: none;
    font-size: .85rem;
    font-weight: 600;
    transition: background .2s;
  }
  .section-nav a:hover { background: var(--clr-accent-lt); }

  /* Sections */
  .peaks-section {
    margin-bottom: 3rem;
    padding-top: 1rem;
    border-top: 2px solid var(--clr-border);
  }
  .peaks-section:first-of-type { border-top: none; }
  .peaks-section h2 { font-size: 1.5rem; margin-bottom: .8rem; }
  .peaks-section p  { color: var(--clr-muted); margin-bottom: 1rem; }

  /* Table */
  .peaks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .9rem;
    margin-top: .5rem;
  }
  .peaks-table th {
    background: var(--clr-accent);
    color: #fff;
    padding: .5rem .8rem;
    text-align: left;
    font-weight: 600;
  }
  .peaks-table td {
    padding: .45rem .8rem;
    border-bottom: 1px solid var(--clr-border);
  }
  .peaks-table tbody tr:nth-child(even) { background: #e8f4fb; }
  .peaks-table tbody tr:hover { background: #d4eaf6; }
</style>
