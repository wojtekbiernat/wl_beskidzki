---
import Layout from '../layouts/Layout.astro';

// TEST link — swap for live URL before going to production
const STRIPE_PAYMENT_LINK = 'https://buy.stripe.com/test_4gM5kF7PganUbttcSo8ww00';
const BOOK_PRICE = '49,90 zł'; // update to match Stripe price
---

<Layout
  title="Zamów"
  description="Zamów książkę [TYTUŁ] — wysyłka na terenie całej Polski. Płatność kartą, BLIK lub Przelewy24."
>

  <div class="page-header">
    <div class="container">
      <h1>Zamów książkę</h1>
      <p>Szybka wysyłka &bull; Bezpieczna płatność &bull; Faktura na życzenie</p>
    </div>
  </div>

  <div class="content-section">
    <div class="container">

      <div class="order-box">

        <!-- Book summary -->
        <div class="order-summary">
          <div class="cover-placeholder">Okładka</div>
          <div class="order-info">
            <h2>[TYTUŁ KSIĄŻKI]</h2>
            <p class="author-name">autor: [Imię Nazwisko]</p>
            <p class="price">{BOOK_PRICE}</p>
            <p class="price-note">Cena zawiera VAT. Koszt wysyłki doliczany przy kasie.</p>
          </div>
        </div>

        <!-- Payment CTA -->
        <div class="payment-section">
          <h3>Wybierz sposób płatności</h3>
          <p class="payment-desc">
            Płatność realizowana jest przez <strong>Stripe</strong> &mdash; bezpieczną,
            szyfrowaną bramkę płatniczą. Akceptujemy:
          </p>
          <ul class="payment-methods">
            <li>&#128179; Karta kredytowa / debetowa (Visa, Mastercard)</li>
            <li>&#128241; BLIK</li>
            <li>&#127988; Przelewy24</li>
            <li>&#127820; Apple Pay / Google Pay</li>
          </ul>

          <a href={STRIPE_PAYMENT_LINK} class="btn btn-order" target="_blank" rel="noopener">
            Przejdź do kasy &rarr;
          </a>
          <p class="secure-note">&#128274; Płatność chroniona szyfrowaniem SSL/TLS</p>
        </div>

        <!-- Shipping info -->
        <div class="shipping-info">
          <h3>Dostawa</h3>
          <table>
            <tbody>
              <tr><td>Poczta Polska (list polecony)</td><td>[X,XX zł]</td></tr>
              <tr><td>Kurier DPD / InPost</td>          <td>[X,XX zł]</td></tr>
              <tr><td>Paczkomat InPost</td>             <td>[X,XX zł]</td></tr>
            </tbody>
          </table>
          <p>Zamówienia realizowane w ciągu <strong>[1–3 dni roboczych]</strong>.</p>
          <p>Potrzebujesz faktury? Wpisz dane firmy w uwagach przy zamówieniu.</p>
        </div>

      </div>

    </div>
  </div>

</Layout>

<style>
  .order-box {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Summary row */
  .order-summary {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .cover-placeholder {
    width: 100px;
    height: 140px;
    background: #e8e0d5;
    border: 2px dashed var(--clr-border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .8rem;
    color: var(--clr-muted);
    flex-shrink: 0;
  }
  .order-info h2 { font-size: 1.3rem; margin-bottom: .3rem; }
  .author-name   { color: var(--clr-muted); font-size: .9rem; margin-bottom: .6rem; }
  .price         { font-size: 1.6rem; font-weight: 700; color: var(--clr-accent); }
  .price-note    { font-size: .8rem; color: var(--clr-muted); margin-top: .2rem; }

  /* Payment */
  .payment-section {
    background: #fff;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    padding: 1.8rem;
  }
  .payment-section h3 { font-size: 1.2rem; margin-bottom: .7rem; }
  .payment-desc { color: var(--clr-muted); margin-bottom: 1rem; font-size: .95rem; }
  .payment-methods {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .4rem;
    margin-bottom: 1.5rem;
    font-size: .95rem;
  }
  .btn-order {
    display: block;
    text-align: center;
    font-size: 1.1rem;
    padding: 1rem;
    background: #2ea44f; /* green — matches "pay" intent */
  }
  .btn-order:hover { background: #22813d; }
  .secure-note {
    text-align: center;
    font-size: .8rem;
    color: var(--clr-muted);
    margin-top: .7rem;
  }

  /* Shipping table */
  .shipping-info {
    background: #f5f0e8;
    border-radius: 8px;
    padding: 1.5rem;
  }
  .shipping-info h3 { font-size: 1.1rem; margin-bottom: .8rem; }
  .shipping-info table { width: 100%; border-collapse: collapse; margin-bottom: .8rem; }
  .shipping-info td   {
    padding: .35rem 0;
    font-size: .9rem;
    border-bottom: 1px solid var(--clr-border);
  }
  .shipping-info td:last-child { text-align: right; font-weight: 600; }
  .shipping-info p { font-size: .9rem; color: var(--clr-muted); margin-top: .5rem; }
</style>
