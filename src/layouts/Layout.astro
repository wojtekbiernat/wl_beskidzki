---
interface Props {
  title: string;
  description?: string;
}

interface DropdownItem { local: string; href: string; label: string; }
interface NavItem      { local: string; href: string; label: string; dropdown?: DropdownItem[]; cta?: boolean; }

const { title, description = 'Beskidzki Włóczykij' } = Astro.props;
const currentPath = Astro.url.pathname;

// BASE_URL is '/' in dev and '/wl_beskidzki/' on GitHub Pages.
const base      = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const url       = (path: string) => `${base}${path.replace(/^\//, '')}`;
const localPath = currentPath.startsWith(base)
  ? '/' + currentPath.slice(base.length)
  : currentPath;

const isActive  = (local: string) =>
  local === '/' ? localPath === '/' : localPath.startsWith(local);

const nav: NavItem[] = [
  {
    local: '/o-projekcie', href: url('/o-projekcie/o-odznace'), label: 'O projekcie',
    dropdown: [
      { local: '/o-projekcie/o-odznace', href: url('/o-projekcie/o-odznace'), label: 'O Odznace' },
      { local: '/o-projekcie/o-nas',     href: url('/o-projekcie/o-nas'),     label: 'O nas'     },
    ],
  },
  {
    local: '/szczyty', href: url('/szczyty/wykaz-szczytow'), label: 'Szczyty',
    dropdown: [
      { local: '/szczyty/wykaz-szczytow', href: url('/szczyty/wykaz-szczytow'), label: 'Wykaz Szczytów' },
      { local: '/szczyty/geografia',      href: url('/szczyty/geografia'),      label: 'Geografia'      },
    ],
  },
  {
    local: '/regulamin', href: url('/regulamin/regulamin'), label: 'Regulaminy',
    dropdown: [
      { local: '/regulamin/regulamin',          href: url('/regulamin/regulamin'),          label: 'Regulamin BW'              },
      { local: '/regulamin/regulamin-ggmf',     href: url('/regulamin/regulamin-ggmf'),     label: 'Regulamin GGMF'            },
      { local: '/regulamin/regulamin-ggwf',     href: url('/regulamin/regulamin-ggwf'),     label: 'Regulamin GGWF'            },
      { local: '/regulamin/regulamin-ggnt',     href: url('/regulamin/regulamin-ggnt'),     label: 'Regulamin GGNT'            },
      { local: '/regulamin/regulamin-eng',      href: url('/regulamin/regulamin-eng'),      label: 'Regulations (EN)'          },
      { local: '/regulamin/regulamin-sklepu',   href: url('/regulamin/regulamin-sklepu'),   label: 'Regulamin sklepu'          },
      { local: '/regulamin/polityka-prywatnosci', href: url('/regulamin/polityka-prywatnosci'), label: 'Polityka prywatności'  },
      { local: '/regulamin/rodo',               href: url('/regulamin/rodo'),               label: 'RODO'                     },
    ],
  },
  { local: '/przystap',    href: url('/przystap'),    label: 'Przystąp', cta: true },
  { local: '/weryfikacja', href: url('/weryfikacja'), label: 'Weryfikacja' },
  {
    local: '/inne-projekty', href: url('/inne-projekty'), label: 'Inne projekty',
    dropdown: [
      { local: '/inne-projekty/korona-slaskiego', href: url('/inne-projekty/korona-slaskiego'), label: 'Korona Woj. Śląskiego'      },
      { local: '/inne-projekty/ggmf',             href: url('/inne-projekty/ggmf'),             label: 'Główny Grzebiet Małej Fatry'    },
      { local: '/inne-projekty/ggwf',             href: url('/inne-projekty/ggwf'),             label: 'Główny Grzebiet Wielkiej Fatry' },
      { local: '/inne-projekty/ggnt',             href: url('/inne-projekty/ggnt'),             label: 'Główny Grzebiet Niżnych Tatr'   },
      { local: '/inne-projekty/korona-wegier',    href: url('/inne-projekty/korona-wegier'),    label: 'Korona Wzgórz i Gór Węgier' },
      { local: '/inne-projekty/koruna-hor',       href: url('/inne-projekty/koruna-hor'),       label: 'Koruna Hor'                 },
    ],
  },
  { local: '/kontakt', href: url('/kontakt'), label: 'Kontakt' },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Beskidzki Włóczykij</title>
    <link rel="icon" type="image/png" href={url('/favicon.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <header>
      <div class="container">
        <a href={base} class="logo">Beskidzki Włóczykij</a>
        <input type="checkbox" id="menu-toggle" hidden />
        <label for="menu-toggle" class="hamburger" aria-label="Menu">&#9776;</label>
        <nav>
          <ul>
            {nav.map(({ href, local, label, dropdown, cta }) => (
              <li class={[dropdown ? 'has-dropdown' : '', cta ? 'nav-cta' : ''].filter(Boolean).join(' ') || undefined}>
                <a href={href} class={cta ? 'nav-cta-btn' : (isActive(local) ? 'active' : '')}>
                  {label}{dropdown && <span class="arrow"> ▾</span>}
                </a>
                {dropdown && (
                  <ul class="dropdown">
                    {dropdown.map(({ href: dHref, local: dLocal, label: dLabel }) => (
                      <li>
                        <a href={dHref} class={isActive(dLocal) ? 'active' : ''}>
                          {dLabel}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Lightbox overlay (activated by any .cover-img click) -->
    <div id="lightbox" role="dialog" aria-modal="true" aria-label="Powiększony widok okładki">
      <button id="lightbox-close" aria-label="Zamknij">&times;</button>
      <img id="lightbox-img" src="" alt="" />
    </div>

    <footer>
      <div class="container">
        <div class="footer-patron">
          <span class="footer-patron-label">Patron Projektu</span>
          <a href="https://pttk.katowice.pl" target="_blank" rel="noopener">
            <img src={url('/img/logo-pttk-szare.png')} alt="PTTK" class="footer-patron-logo" />
          </a>
        </div>
        <p class="footer-seller">Sprzedaż internetową książeczek prowadzi Aleksandra Torbus w ramach działalności nierejestrowanej. Szczegóły znajdują się w <a href={url('/regulamin/regulamin')}>Regulaminie sklepu i Polityce prywatności</a>.</p>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Beskidzki Włóczykij. Wszelkie prawa zastrzeżone.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --clr-bg:        #f0f7fc;
    --clr-text:      #1a1a1a;
    --clr-muted:     #555;
    --clr-accent:    #358dc2;
    --clr-accent-lt: #67BED9;
    --clr-border:    #b8ddf0;
    --font-serif:    'Source Sans 3', system-ui, sans-serif;
    --font-sans:     'Source Sans 3', system-ui, sans-serif;
    --max-w:         860px;
  }

  body {
    font-family: var(--font-sans);
    background: var(--clr-bg);
    color: var(--clr-text);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main { flex: 1; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  header {
    background: var(--clr-accent);
    color: #fff;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,.25);
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    height: 60px;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: .03em;
    white-space: nowrap;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.2rem;
  }

  nav a {
    color: rgba(255,255,255,.85);
    text-decoration: none;
    font-size: .9rem;
    font-weight: 600;
    letter-spacing: .02em;
    transition: color .2s;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  nav a:hover, nav a.active {
    color: #fff;
    border-bottom-color: #fff;
  }

  /* ── CTA pill ("Przystąp") ── */
  nav ul li.nav-cta {
    margin-left: .4rem;
    align-self: center;
    position: relative; /* create stacking context */
    z-index: 201;       /* sit above dropdown panels (z-index 200) */
  }

  /* Class applied directly to <a> — no child combinator needed */
  nav a.nav-cta-btn {
    background: #fff;
    color: var(--clr-accent);
    padding: .32rem .9rem;
    border-radius: 20px;
    border-bottom: none;
    font-weight: 700;
    font-size: .88rem;
    transition: background .18s, color .18s, box-shadow .18s;
    box-shadow: 0 0 0 2px rgba(255,255,255,.5);
  }

  nav a.nav-cta-btn:hover {
    background: var(--clr-accent-lt);
    color: var(--clr-accent);
    border-bottom: none;
    box-shadow: 0 0 0 2px rgba(255,255,255,.8);
  }

  /* ── Dropdown ── */
  nav ul li.has-dropdown { position: relative; }

  .arrow {
    font-size: .7rem;
    display: inline-block;
    transition: transform .2s;
  }

  nav ul li.has-dropdown > ul.dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--clr-accent);
    min-width: 210px;
    border-top: 2px solid rgba(255,255,255,.25);
    border-radius: 0 0 4px 4px;
    box-shadow: 0 6px 16px rgba(0,0,0,.25);
    z-index: 200;
    padding: .4rem 0;
  }

  nav ul li.has-dropdown:hover > ul.dropdown,
  nav ul li.has-dropdown:focus-within > ul.dropdown { display: block; }

  nav ul li.has-dropdown:hover .arrow,
  nav ul li.has-dropdown:focus-within .arrow { transform: rotate(180deg); }

  nav ul li.has-dropdown > ul.dropdown li { display: block; }

  nav ul li.has-dropdown > ul.dropdown a {
    display: block;
    padding: .45rem 1.1rem;
    border-bottom: none;
    font-size: .88rem;
  }

  nav ul li.has-dropdown > ul.dropdown a:hover,
  nav ul li.has-dropdown > ul.dropdown a.active {
    background: rgba(255,255,255,.12);
    border-bottom: none;
  }

  .hamburger {
    display: none;
    font-size: 1.5rem;
    color: #fff;
    cursor: pointer;
    user-select: none;
  }

  @media (max-width: 640px) {
    .hamburger { display: block; }

    nav {
      display: none;
      position: absolute;
      top: 60px; left: 0; right: 0;
      background: var(--clr-accent);
      padding: 1rem 1.5rem;
      max-height: calc(100vh - 60px);
      overflow-y: auto;
    }

    #menu-toggle:checked ~ nav { display: block; }

    nav ul { flex-direction: column; gap: .5rem; }

    /* Show dropdowns inline on mobile */
    nav ul li.has-dropdown > ul.dropdown {
      display: block;
      position: static;
      box-shadow: none;
      border-top: none;
      border-radius: 0;
      padding: .3rem 0 .3rem 1rem;
      border-left: 2px solid rgba(255,255,255,.3);
      margin-top: .3rem;
      min-width: 0;
    }

    nav ul li.has-dropdown > ul.dropdown a {
      padding: .3rem .5rem;
    }
  }

  /* ── Footer ── */
  footer {
    background: var(--clr-accent);
    color: rgba(255,255,255,.7);
    padding: 1.5rem 0 1.2rem;
    text-align: center;
    font-size: .875rem;
    margin-top: 4rem;
  }
  .footer-patron {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .8rem;
    margin-bottom: .9rem;
  }
  .footer-patron-label {
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .7rem;
    opacity: .7;
  }
  .footer-patron-logo {
    height: 42px;
    width: auto;
    opacity: .85;
    transition: opacity .2s;
  }
  .footer-patron-logo:hover { opacity: 1; }
  .footer-seller { opacity: .65; font-size: .75rem; margin-bottom: .4rem; }
  .footer-seller a { color: rgba(255,255,255,.85); text-decoration: underline; }
  .footer-copy { opacity: .7; font-size: .8rem; }

  /* ── Shared helpers ── */
  h1, h2, h3 { font-family: var(--font-serif); line-height: 1.25; }

  .page-header {
    background: var(--clr-accent-lt);
    color: #fff;
    padding: 3rem 0 2.5rem;
    text-align: center;
  }
  .page-header h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: .5rem; }
  .page-header p  { opacity: .85; font-size: 1.05rem; }

  .content-section { padding: 3rem 0; }

  .btn {
    display: inline-block;
    background: var(--clr-accent);
    color: #fff;
    padding: .75rem 1.8rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background .2s, transform .1s;
    border: none;
    cursor: pointer;
  }
  .btn:hover { background: var(--clr-accent-lt); transform: translateY(-1px); }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--clr-accent);
    color: var(--clr-accent);
  }
  .btn-outline:hover { background: var(--clr-accent); color: #fff; }

  /* ── Lightbox ── */
  .cover-img { cursor: zoom-in; }

  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .82);
    z-index: 9000;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  #lightbox.open { display: flex; }

  #lightbox-img {
    max-width: min(480px, 90vw);
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 8px 40px rgba(0,0,0,.6);
    animation: lb-in .2s ease;
  }

  #lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1.2rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 2.4rem;
    line-height: 1;
    cursor: pointer;
    opacity: .8;
    transition: opacity .15s;
    z-index: 9001;
  }
  #lightbox-close:hover { opacity: 1; }

  @keyframes lb-in {
    from { transform: scale(.88); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
</style>

<script is:inline>
  (function () {
    var lb    = document.getElementById('lightbox');
    var lbImg = document.getElementById('lightbox-img');
    var lbBtn = document.getElementById('lightbox-close');
    if (!lb || !lbImg || !lbBtn) return;

    function open(src, alt) {
      lbImg.src = src;
      lbImg.alt = alt || '';
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.cover-img').forEach(function (img) {
      img.addEventListener('click', function () { open(img.src, img.alt); });
    });

    lbBtn.addEventListener('click', close);
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  })();
</script>
