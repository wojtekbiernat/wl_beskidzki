---
interface Props {
  title: string;
  description?: string;
}

interface DropdownItem { local: string; href: string; label: string; }
interface NavItem      { local: string; href: string; label: string; dropdown?: DropdownItem[]; }

const { title, description = 'Włóczykij Beskidzki' } = Astro.props;
const currentPath = Astro.url.pathname;

// BASE_URL is '/' in dev and '/wl_beskidzki/' on GitHub Pages.
const base      = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const url       = (path: string) => `${base}${path.replace(/^\//, '')}`;
const localPath = currentPath.startsWith(base)
  ? '/' + currentPath.slice(base.length)
  : currentPath;

const isActive  = (local: string) =>
  local === '/' ? localPath === '/' : localPath.startsWith(local);

const nav: NavItem[] = [
  {
    local: '/o-projekcie', href: url('/o-projekcie/o-odznace'), label: 'O projekcie',
    dropdown: [
      { local: '/o-projekcie/o-odznace', href: url('/o-projekcie/o-odznace'), label: 'O Odznace' },
      { local: '/o-projekcie/o-nas',     href: url('/o-projekcie/o-nas'),     label: 'O nas'     },
    ],
  },
  { local: '/szczyty', href: url('/szczyty'), label: 'Szczyty' },
  {
    local: '/regulamin', href: url('/regulamin/regulamin'), label: 'Regulamin',
    dropdown: [
      { local: '/regulamin/regulamin', href: url('/regulamin/regulamin'), label: 'Regulamin' },
      { local: '/regulamin/rodo',      href: url('/regulamin/rodo'),      label: 'RODO'      },
    ],
  },
  { local: '/przystap',    href: url('/przystap'),    label: 'Przystąp'    },
  { local: '/weryfikacja', href: url('/weryfikacja'), label: 'Weryfikacja' },
  {
    local: '/inne-projekty', href: url('/inne-projekty/korona-slaskiego'), label: 'Inne projekty',
    dropdown: [
      { local: '/inne-projekty/korona-slaskiego', href: url('/inne-projekty/korona-slaskiego'), label: 'Korona Woj. Śląskiego'      },
      { local: '/inne-projekty/ggmf',             href: url('/inne-projekty/ggmf'),             label: 'GGMF'                        },
      { local: '/inne-projekty/ggwf',             href: url('/inne-projekty/ggwf'),             label: 'GGWF'                        },
      { local: '/inne-projekty/ggnt',             href: url('/inne-projekty/ggnt'),             label: 'GGNT'                        },
      { local: '/inne-projekty/korona-wegier',    href: url('/inne-projekty/korona-wegier'),    label: 'Korona Wzgórz i Gór Węgier' },
    ],
  },
  { local: '/kontakt', href: url('/kontakt'), label: 'Kontakt' },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Włóczykij Beskidzki</title>
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="container">
        <a href={base} class="logo">Włóczykij Beskidzki</a>
        <input type="checkbox" id="menu-toggle" hidden />
        <label for="menu-toggle" class="hamburger" aria-label="Menu">&#9776;</label>
        <nav>
          <ul>
            {nav.map(({ href, local, label, dropdown }) => (
              <li class={dropdown ? 'has-dropdown' : ''}>
                <a href={href} class={isActive(local) ? 'active' : ''}>
                  {label}{dropdown && <span class="arrow"> ▾</span>}
                </a>
                {dropdown && (
                  <ul class="dropdown">
                    {dropdown.map(({ href: dHref, local: dLocal, label: dLabel }) => (
                      <li>
                        <a href={dHref} class={isActive(dLocal) ? 'active' : ''}>
                          {dLabel}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} WL Beskidzki. Wszelkie prawa zastrzeżone.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --clr-bg:        #f0f7fc;
    --clr-text:      #1a1a1a;
    --clr-muted:     #555;
    --clr-accent:    #358dc2;
    --clr-accent-lt: #67BED9;
    --clr-border:    #b8ddf0;
    --font-serif:    'Playfair Display', Georgia, serif;
    --font-sans:     'Source Sans 3', system-ui, sans-serif;
    --max-w:         860px;
  }

  body {
    font-family: var(--font-sans);
    background: var(--clr-bg);
    color: var(--clr-text);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main { flex: 1; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  header {
    background: var(--clr-accent);
    color: #fff;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,.25);
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: .03em;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.2rem;
  }

  nav a {
    color: rgba(255,255,255,.85);
    text-decoration: none;
    font-size: .9rem;
    font-weight: 600;
    letter-spacing: .02em;
    transition: color .2s;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  nav a:hover, nav a.active {
    color: #fff;
    border-bottom-color: #fff;
  }

  /* ── Dropdown ── */
  nav ul li.has-dropdown { position: relative; }

  .arrow {
    font-size: .7rem;
    display: inline-block;
    transition: transform .2s;
  }

  nav ul li.has-dropdown > ul.dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--clr-accent);
    min-width: 210px;
    border-top: 2px solid rgba(255,255,255,.25);
    border-radius: 0 0 4px 4px;
    box-shadow: 0 6px 16px rgba(0,0,0,.25);
    z-index: 200;
    padding: .4rem 0;
  }

  nav ul li.has-dropdown:hover > ul.dropdown,
  nav ul li.has-dropdown:focus-within > ul.dropdown { display: block; }

  nav ul li.has-dropdown:hover .arrow,
  nav ul li.has-dropdown:focus-within .arrow { transform: rotate(180deg); }

  nav ul li.has-dropdown > ul.dropdown li { display: block; }

  nav ul li.has-dropdown > ul.dropdown a {
    display: block;
    padding: .45rem 1.1rem;
    border-bottom: none;
    font-size: .88rem;
  }

  nav ul li.has-dropdown > ul.dropdown a:hover,
  nav ul li.has-dropdown > ul.dropdown a.active {
    background: rgba(255,255,255,.12);
    border-bottom: none;
  }

  .hamburger {
    display: none;
    font-size: 1.5rem;
    color: #fff;
    cursor: pointer;
    user-select: none;
  }

  @media (max-width: 640px) {
    .hamburger { display: block; }

    nav {
      display: none;
      position: absolute;
      top: 60px; left: 0; right: 0;
      background: var(--clr-accent);
      padding: 1rem 1.5rem;
    }

    #menu-toggle:checked ~ nav { display: block; }

    nav ul { flex-direction: column; gap: .5rem; }

    /* Show dropdowns inline on mobile */
    nav ul li.has-dropdown > ul.dropdown {
      display: block;
      position: static;
      box-shadow: none;
      border-top: none;
      border-radius: 0;
      padding: .3rem 0 .3rem 1rem;
      border-left: 2px solid rgba(255,255,255,.3);
      margin-top: .3rem;
      min-width: 0;
    }

    nav ul li.has-dropdown > ul.dropdown a {
      padding: .3rem .5rem;
    }
  }

  /* ── Footer ── */
  footer {
    background: var(--clr-accent);
    color: rgba(255,255,255,.7);
    padding: 1.2rem 0;
    text-align: center;
    font-size: .875rem;
    margin-top: 4rem;
  }

  /* ── Shared helpers ── */
  h1, h2, h3 { font-family: var(--font-serif); line-height: 1.25; }

  .page-header {
    background: var(--clr-accent-lt);
    color: #fff;
    padding: 3rem 0 2.5rem;
    text-align: center;
  }
  .page-header h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: .5rem; }
  .page-header p  { opacity: .85; font-size: 1.05rem; }

  .content-section { padding: 3rem 0; }

  .btn {
    display: inline-block;
    background: var(--clr-accent);
    color: #fff;
    padding: .75rem 1.8rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background .2s, transform .1s;
    border: none;
    cursor: pointer;
  }
  .btn:hover { background: var(--clr-accent-lt); transform: translateY(-1px); }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--clr-accent);
    color: var(--clr-accent);
  }
  .btn-outline:hover { background: var(--clr-accent); color: #fff; }
</style>
