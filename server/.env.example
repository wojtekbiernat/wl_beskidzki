# Copy this file to .env and fill in real values.
# The .env file must NEVER be committed to git.

# Your hCaptcha secret key (from hcaptcha.com dashboard)
HCAPTCHA_SECRET=your_hcaptcha_secret_key

# Stripe webhook signing secret (from Stripe Dashboard > Webhooks > your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Recipient(s) for contact form messages — comma-separated for multiple
# CONTACT_EMAIL=you@gmail.com,colleague@gmail.com
CONTACT_EMAIL=you@example.com

# Must match the envelope sender in sendmail_path (the -f flag in php.ini).
# Run test-mail.php to find yours — look for "-f someuser@yourdomain.com"
FROM_EMAIL=admin@korunahor.cz

# Absolute path to WordPress root (where wp-load.php lives).
# Default: one directory above this script — only set if your layout differs.
# WP_ROOT=/home/pmpjzine/domains/korunahor.cz/public_html

# The exact origin of your frontend (used for CORS — no trailing slash)
# For local dev:   ALLOWED_ORIGIN=http://localhost:4321
# For production:  ALLOWED_ORIGIN=https://wojtekbiernat.github.io
ALLOWED_ORIGIN=https://wojtekbiernat.github.io
